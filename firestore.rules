rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    function isAnyRole(roles) {
      return isSignedIn() && getUserData().role in roles;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Users & notifications ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAnyRole(['CEO', 'HR', 'ACCOUNTANT', 'OPERATOR']);
      allow list: if isAnyRole(['CEO', 'HR', 'ACCOUNTANT', 'OPERATOR']);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if (isOwner(userId) && resource != null) || hasRole('CEO');
      allow delete: if hasRole('CEO') && resource != null;

      match /notifications/{notificationId} {
        allow read, write, delete: if isOwner(userId) || hasRole('CEO');
      }
    }

    match /meetings/{meetingId} {
      allow read: if isAnyRole(['CEO', 'HR']) || (isSignedIn() && resource.data.participants != null && request.auth.uid in resource.data.participants);
      allow create, update: if isAnyRole(['CEO', 'HR']);
      allow delete: if hasRole('CEO') && resource != null;
    }

    match /customers/{customerId} {
      allow read: if isAnyRole(['CEO', 'HR', 'OPERATOR', 'ACCOUNTANT']);
      allow create, update, delete: if hasRole('CEO');
    }

    // App uses snake_case collection names (see src/)

    match /fleet_vehicles/{id} {
      allow read: if isAnyRole(['CEO', 'HR', 'OPERATOR', 'MECHANIC', 'DRIVER']);
      allow create, update: if isAnyRole(['CEO', 'OPERATOR']);
      allow delete: if hasRole('CEO');
    }

    match /trips/{tripId} {
      allow read: if isAnyRole(['CEO', 'HR', 'OPERATOR', 'ACCOUNTANT']) || (resource.data.driverId == request.auth.uid);
      allow create: if isAnyRole(['CEO', 'OPERATOR']);
      allow update: if (isAnyRole(['CEO', 'OPERATOR']) && resource != null) || (resource != null && resource.data.driverId == request.auth.uid);
      allow delete: if hasRole('CEO');
    }

    match /trips/{tripId}/delivery_proofs/{proofId} {
      allow read: if isAnyRole(['CEO', 'HR', 'OPERATOR', 'ACCOUNTANT'])
        || (exists(/databases/$(database)/documents/trips/$(tripId))
            && get(/databases/$(database)/documents/trips/$(tripId)).data.driverId == request.auth.uid);
      allow create: if isSignedIn()
        && exists(/databases/$(database)/documents/trips/$(tripId))
        && get(/databases/$(database)/documents/trips/$(tripId)).data.driverId == request.auth.uid;
      allow update, delete: if hasRole('CEO');
    }

    match /allowances/{id} {
      allow read: if isAnyRole(['CEO', 'HR', 'ACCOUNTANT']) || (resource.data.userId == request.auth.uid);
      allow create, update: if isAnyRole(['ACCOUNTANT', 'CEO']);
      allow delete: if hasRole('CEO');
    }

    match /fuel_requests/{id} {
      allow read: if isAnyRole(['CEO', 'HR', 'ACCOUNTANT', 'OPERATOR']) || (resource.data.driverId == request.auth.uid);
      allow create: if isAnyRole(['DRIVER', 'CEO', 'OPERATOR']) && request.resource.data.driverId == request.auth.uid;
      allow update: if isAnyRole(['ACCOUNTANT', 'OPERATOR', 'CEO']);
      allow delete: if hasRole('CEO');
    }

    match /maintenance_requests/{id} {
      allow read: if isAnyRole(['CEO', 'HR', 'OPERATOR', 'MECHANIC', 'DRIVER']);
      allow create: if isAnyRole(['MECHANIC', 'DRIVER', 'OPERATOR', 'CEO']);
      allow update: if isAnyRole(['MECHANIC', 'OPERATOR', 'CEO']);
      allow delete: if hasRole('CEO');
    }

    match /inventory_items/{id} {
      allow read: if isAnyRole(['CEO', 'HR', 'OPERATOR', 'MECHANIC']);
      allow create, update: if isAnyRole(['OPERATOR', 'CEO', 'MECHANIC']);
      allow delete: if hasRole('CEO');
    }

    match /spare_parts_requests/{id} {
      allow read: if isAnyRole(['CEO', 'HR', 'OPERATOR', 'MECHANIC']);
      allow create: if isAnyRole(['MECHANIC', 'OPERATOR', 'CEO']);
      allow update: if isAnyRole(['OPERATOR', 'CEO']);
      allow delete: if hasRole('CEO');
    }

    match /driver_locations/{driverId} {
      allow read: if isAnyRole(['CEO', 'HR', 'OPERATOR']);
      allow create, update: if request.auth.uid == driverId || hasRole('CEO');
      allow delete: if hasRole('CEO');
    }

    match /roles_driver/{id} {
      allow read: if isAnyRole(['CEO', 'HR', 'OPERATOR']);
      allow write, delete: if hasRole('CEO');
    }

    match /roles_mechanic/{id} {
      allow read: if isAnyRole(['CEO', 'HR', 'OPERATOR', 'MECHANIC']);
      allow write, delete: if hasRole('CEO');
    }

    // Finance ledgers (accountant + CEO; CEO deletes)

    match /sales/{id} {
      allow read: if isAnyRole(['CEO', 'HR', 'ACCOUNTANT']);
      allow create, update: if isAnyRole(['ACCOUNTANT', 'CEO']);
      allow delete: if hasRole('CEO');
    }

    match /purchases/{id} {
      allow read: if isAnyRole(['CEO', 'HR', 'ACCOUNTANT']);
      allow create, update: if isAnyRole(['ACCOUNTANT', 'CEO']);
      allow delete: if hasRole('CEO');
    }

    match /expenses/{id} {
      allow read: if isAnyRole(['CEO', 'HR', 'ACCOUNTANT', 'OPERATOR']);
      allow create: if isAnyRole(['DRIVER', 'ACCOUNTANT', 'CEO']);
      allow update: if isAnyRole(['ACCOUNTANT', 'CEO']);
      allow delete: if hasRole('CEO');
    }

    match /taxes/{id} {
      allow read: if isAnyRole(['CEO', 'HR', 'ACCOUNTANT']);
      allow create, update: if isAnyRole(['ACCOUNTANT', 'CEO']);
      allow delete: if hasRole('CEO');
    }

    match /invoices/{id} {
      allow read: if isAnyRole(['CEO', 'HR', 'ACCOUNTANT']);
      allow create, update: if isAnyRole(['ACCOUNTANT', 'CEO']);
      allow delete: if hasRole('CEO');
    }

    match /financial_reports/{id} {
      allow read: if isAnyRole(['CEO', 'HR', 'ACCOUNTANT']);
      allow create, update: if isAnyRole(['ACCOUNTANT', 'CEO']);
      allow delete: if hasRole('CEO');
    }

    match /income/{id} {
      allow read: if isAnyRole(['CEO', 'HR', 'ACCOUNTANT']);
      allow create, update: if isAnyRole(['ACCOUNTANT', 'CEO']);
      allow delete: if hasRole('CEO');
    }

    // Legacy camelCase paths (keep if old data exists)

    match /fleetVehicles/{id} {
      allow read: if isAnyRole(['CEO', 'HR', 'OPERATOR', 'MECHANIC', 'DRIVER']);
      allow create: if isAnyRole(['CEO', 'OPERATOR']);
      allow update: if isAnyRole(['CEO', 'OPERATOR', 'MECHANIC']);
      allow delete: if hasRole('CEO');
    }

    match /incomeRecords/{id} {
      allow read: if isAnyRole(['CEO', 'HR', 'ACCOUNTANT']);
      allow create, update: if hasRole('ACCOUNTANT');
      allow delete: if hasRole('CEO');
    }

    match /expenseRecords/{id} {
      allow read: if isAnyRole(['CEO', 'HR', 'ACCOUNTANT', 'OPERATOR']);
      allow create: if isAnyRole(['ACCOUNTANT', 'OPERATOR', 'CEO']);
      allow update: if isAnyRole(['ACCOUNTANT', 'CEO']);
      allow delete: if hasRole('CEO');
    }

    match /fuelRequests/{id} {
      allow read: if isAnyRole(['CEO', 'HR', 'ACCOUNTANT', 'OPERATOR']) || (resource.data.driverId == request.auth.uid);
      allow create: if isAnyRole(['DRIVER', 'CEO', 'OPERATOR']) && request.resource.data.driverId == request.auth.uid;
      allow update: if isAnyRole(['ACCOUNTANT', 'OPERATOR', 'CEO']);
      allow delete: if hasRole('CEO');
    }

    match /inventoryItems/{id} {
      allow read: if isAnyRole(['CEO', 'HR', 'OPERATOR', 'MECHANIC']);
      allow create: if isAnyRole(['OPERATOR', 'CEO']);
      allow update: if isAnyRole(['OPERATOR', 'MECHANIC', 'CEO']);
      allow delete: if hasRole('CEO');
    }

    match /inventoryUsageLogs/{id} {
      allow read: if isAnyRole(['CEO', 'HR', 'OPERATOR', 'MECHANIC']);
      allow create: if isAnyRole(['MECHANIC', 'OPERATOR', 'CEO']);
      allow update, delete: if hasRole('CEO');
    }

    match /sparePartsRequests/{id} {
      allow read: if isAnyRole(['CEO', 'HR', 'OPERATOR', 'MECHANIC']);
      allow create: if isAnyRole(['MECHANIC', 'OPERATOR', 'CEO']);
      allow update: if isAnyRole(['OPERATOR', 'CEO']);
      allow delete: if hasRole('CEO');
    }

    match /deliveryProofs/{id} {

    // New Fleet Management Collections
    
    match /vehicles/{id} {
      allow read: if isAnyRole(['CEO', 'HR', 'OPERATOR', 'MECHANIC', 'DRIVER']) || isSignedIn();
      allow create, update: if isAnyRole(['CEO', 'OPERATOR']) || isSignedIn();
      allow delete: if hasRole('CEO');
    }
    
    match /trips/{id} {
      allow read: if isAnyRole(['CEO', 'HR', 'OPERATOR', 'ACCOUNTANT']) || (resource.data.driverId == request.auth.uid) || isSignedIn();
      allow create: if isAnyRole(['CEO', 'OPERATOR']) || isSignedIn();
      allow update: if (isAnyRole(['CEO', 'OPERATOR']) && resource != null) || (resource != null && resource.data.driverId == request.auth.uid) || isSignedIn();
      allow delete: if hasRole('CEO');
    }
    
    match /expenses/{id} {
      allow read: if isAnyRole(['CEO', 'HR', 'ACCOUNTANT', 'OPERATOR']) || (resource.data.driverId == request.auth.uid) || isSignedIn();
      allow create: if isAnyRole(['DRIVER', 'ACCOUNTANT', 'CEO']) || isSignedIn();
      allow update: if isAnyRole(['ACCOUNTANT', 'CEO']) || isSignedIn();
      allow delete: if hasRole('CEO');
    }
    
    match /maintenance_requests/{id} {
      allow read: if isAnyRole(['CEO', 'HR', 'OPERATOR', 'MECHANIC', 'DRIVER']) || isSignedIn();
      allow create: if isAnyRole(['MECHANIC', 'DRIVER', 'OPERATOR', 'CEO']) || isSignedIn();
      allow update: if isAnyRole(['MECHANIC', 'OPERATOR', 'CEO']) || isSignedIn();
      allow delete: if hasRole('CEO');
    }
    
    match /spare_parts/{id} {
      allow read: if isAnyRole(['CEO', 'HR', 'OPERATOR', 'MECHANIC']) || isSignedIn();
      allow create, update: if isAnyRole(['OPERATOR', 'CEO', 'MECHANIC']) || isSignedIn();
      allow delete: if hasRole('CEO');
    }
    
    match /parts_requests/{id} {
      allow read: if isAnyRole(['CEO', 'HR', 'OPERATOR', 'MECHANIC']) || isSignedIn();
      allow create: if isAnyRole(['MECHANIC', 'OPERATOR', 'CEO']) || isSignedIn();
      allow update: if isAnyRole(['OPERATOR', 'CEO']) || isSignedIn();
      allow delete: if hasRole('CEO');
    }
    
    match /allowances/{id} {
      allow read: if isAnyRole(['CEO', 'HR', 'ACCOUNTANT']) || (resource.data.employeeId == request.auth.uid) || isSignedIn();
      allow create, update: if isAnyRole(['ACCOUNTANT', 'CEO', 'HR']) || isSignedIn();
      allow delete: if hasRole('CEO');
    }

    // CEO: full access to any path not matched above (covers new collections and admin tasks)
    match /{document=**} {
      allow read, write, delete: if hasRole('CEO');
    }
  }
}
}␀␀
␀}␀␀
␀